checkpoints/
models/
weights/
*.ckpt
*.pt
*.pth
*.safetensors
*.onnx

# OS and editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# Local Codex/session state
.codex
