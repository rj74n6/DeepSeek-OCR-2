__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/

# Virtual environments and local package state
.venv/
venv/
env/
ENV/
.uv-cache/

# Build and packaging output
build/
dist/
*.egg-info/
.eggs/

# Jupyter and notebook checkpoints
.ipynb_checkpoints/

# Logs and runtime output
*.log
logs/
outputs/
runs/
tmp/
temp/

